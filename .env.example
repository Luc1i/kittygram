# Пример .env — скопируй в файл `.env` рядом и поправь при необходимости

SECRET_KEY=поменяй-если-выложишь-на-github

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

PAGE_SIZE=10

SQLITE_NAME=db.sqlite3

# секрет для выдачи staff через API (register staff_key или POST /api/auth/promote-self/)
# если оставить пустым — через API staff не получить
REGISTER_STAFF_KEY=local-dev-staff-secret
